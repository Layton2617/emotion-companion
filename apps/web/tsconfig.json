{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Next 自带类型生成与增量构建,与 base 的 composite 项目引用模式冲突,这里关掉。
    "composite": false,
    "declaration": false,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
